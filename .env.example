# Copia in .env e compila i valori

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/restaurant_ai

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Twilio WhatsApp (opzionale — senza, gli alert vanno solo in console)
# Crea account su twilio.com → usa il Sandbox WhatsApp gratuito
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=+14155238886

# Server
PORT=3001
NODE_ENV=development
